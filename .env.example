# Copy this file to .env.local and fill in real values
MONGODB_URI=mongodb://localhost:27017/crudstudio
# OR use MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/crudstudio

# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string-min-32-chars

# Admin credentials (used by the seed script to create the first user)
ADMIN_EMAIL=admin@crudstudio.com
ADMIN_PASSWORD=changeme123
